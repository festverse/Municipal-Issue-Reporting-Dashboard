# ==========================================
# Server Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string
# For Docker Compose: postgresql://municipal_user:municipal_pass@localhost:5432/municipal_dashboard
# For Neon/Supabase: your cloud connection string
DATABASE_URL=postgresql://municipal_user:municipal_pass@localhost:5432/municipal_dashboard

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development
